// ============================================================
// Lox Expression Parser Test File
// Grammar: expression → equality → comparison → term →
//          factor → unary → primary
// ============================================================


// ------------------------------------------------------------
// PRIMARY: NUMBER, STRING, BOOL literals, nil, grouping
// ------------------------------------------------------------

42;
3.14;
"hello";
"";
true;
false;
nil;
(42);
("grouped string");


// ------------------------------------------------------------
// UNARY: ! and - applied to primary
// ------------------------------------------------------------

!true;
!false;
!nil;
-42;
-3.14;
!!true;
--1;
!(!false);


// ------------------------------------------------------------
// FACTOR: * and / (unary * unary)
// ------------------------------------------------------------

2 * 3;
10 / 2;
3 * 3 * 3;
10 / 2 / 5;
-4 * 2;
10 / -2;
2 * (3 / 1);
(6 / 2) * (4 * 1);


// ------------------------------------------------------------
// TERM: + and - (factor + factor)
// ------------------------------------------------------------

1 + 2;
10 - 4;
1 + 2 + 3;
10 - 3 - 2;
1 + 2 * 3;       // factor before term: should be 1 + (2*3) = 7
10 - 4 / 2;      // should be 10 - (4/2) = 8
(1 + 2) * 3;
"hello" + " " + "world";


// ------------------------------------------------------------
// COMPARISON: >, >=, <, <= (term op term)
// ------------------------------------------------------------

1 < 2;
2 > 1;
2 >= 2;
1 <= 1;
3 >= 4;
5 < 3;
1 + 1 < 3;
10 - 1 > 8;
2 * 3 >= 6;
10 / 2 <= 4;


// ------------------------------------------------------------
// EQUALITY: == and != (comparison op comparison)
// ------------------------------------------------------------

1 == 1;
1 != 2;
"hello" == "hello";
"hello" != "world";
true == true;
false != true;
nil == nil;
1 + 1 == 2;
2 * 3 != 5;
(1 < 2) == true;
true == !false;
nil != false;


// ------------------------------------------------------------
// DEEPLY NESTED / COMBINED EXPRESSIONS
// ------------------------------------------------------------

// Arithmetic nesting
((2 + 3) * (4 - 1)) / 5;

// Unary chained with comparison
-5 < -3;
!true == false;
!(1 == 2);

// Multi-level grouping
((((42))));

// Mixed types in equality (valid parse, semantics aside)
1 == "1";
nil == false;
true == 1;

// Long chain
1 + 2 + 3 + 4 + 5;
10 - 1 - 2 - 3;
2 * 3 * 4 * 5;
100 / 2 / 5 / 2;

// Complex nested
(1 + 2) * (3 + 4) == 21;
!(3 * 3 == 10);
(10 / 2) >= (3 + 1);
("a" == "a") == true;
((1 + 1) * (2 + 2)) / (2 * 2) == 1;
